[% set supported_profiles = ['python', 'typescript', 'rust', 'go', 'elixir', 'nix', 'other'] %]
[% set profile_validation = namespace(invalid=false, canonical=[]) %]
[% if language_profiles is mapping or language_profiles is string or language_profiles is not sequence or not language_profiles %]
[% set profile_validation.invalid = true %]
[% else %]
[% for profile in language_profiles %]
[% if profile not in supported_profiles %][% set profile_validation.invalid = true %][% endif %]
[% endfor %]
[% if language_profiles | unique | list | length != language_profiles | length %]
[% set profile_validation.invalid = true %]
[% endif %]
[% if 'other' in language_profiles and language_profiles | length > 1 %]
[% set profile_validation.invalid = true %]
[% endif %]
[% for profile in supported_profiles %]
[% if profile in language_profiles %][% set profile_validation.canonical = profile_validation.canonical + [profile] %][% endif %]
[% endfor %]
[% if language_profiles != profile_validation.canonical %][% set profile_validation.invalid = true %][% endif %]
[% endif %]
[# Copier accepts trusted pre-supplied data without question validation; force invalid direct renders to fail. #]
[% if profile_validation.invalid %][[ 1 / 0 ]][% endif %]
[% if dstack_template_channel not in ['stable', 'unstable'] %][[ 1 / 0 ]][% endif %]
[% set layout_validation = namespace(invalid=false, paths=[], slugs=[]) %]
[% if repository_layout not in ['single-package', 'monorepo'] %][% set layout_validation.invalid = true %][% endif %]
[% if monorepo_packages is mapping or monorepo_packages is string or monorepo_packages is not sequence %][% set layout_validation.invalid = true %][% endif %]
[% if repository_layout == 'single-package' and monorepo_packages %][% set layout_validation.invalid = true %][% endif %]
[% if repository_layout == 'monorepo' and (monorepo_packages | length < 1 or monorepo_packages | length > 32) %][% set layout_validation.invalid = true %][% endif %]
[% for package in monorepo_packages %]
[% if package is not mapping or package.keys() | sort | list != ['display_name', 'language_profiles', 'path', 'slug'] %][% set layout_validation.invalid = true %][% endif %]
[% if package.display_name is not string or not package.display_name | trim or '\n' in package.display_name or '\r' in package.display_name %][% set layout_validation.invalid = true %][% endif %]
[% if package.slug is not string or not package.slug or package.slug != package.slug | lower or package.slug.startswith('-') or package.slug.endswith('-') or '--' in package.slug %][% set layout_validation.invalid = true %][% endif %]
[% if package.path is not string or not package.path or package.path.startswith('/') or '\\' in package.path or '' in package.path.split('/') or '.' in package.path.split('/') or '..' in package.path.split('/') %][% set layout_validation.invalid = true %][% endif %]
[% for character in package.path if character not in 'ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789._-/' %][% set layout_validation.invalid = true %][% endfor %]
[% for component in package.path.split('/') %][% if component and component[0] not in 'ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789' %][% set layout_validation.invalid = true %][% endif %][% endfor %]
[% if package.path.casefold() in layout_validation.paths or package.slug.casefold() in layout_validation.slugs %][% set layout_validation.invalid = true %][% endif %]
[% set layout_validation.paths = layout_validation.paths + [package.path.casefold()] %]
[% set layout_validation.slugs = layout_validation.slugs + [package.slug.casefold()] %]
[% endfor %]
[% set package_union = namespace(selected=[]) %]
[% for profile in supported_profiles if profile != 'other' %]
[% for package in monorepo_packages if profile in package.language_profiles %][% if profile not in package_union.selected %][% set package_union.selected = package_union.selected + [profile] %][% endif %][% endfor %]
[% endfor %]
[% if not package_union.selected %][% for package in monorepo_packages if 'other' in package.language_profiles %][% set package_union.selected = ['other'] %][% endfor %][% endif %]
[% if repository_layout == 'monorepo' and language_profiles != package_union.selected %][% set layout_validation.invalid = true %][% endif %]
[# Copier accepts trusted pre-supplied data without question validation; force invalid direct layout renders to fail. #]
[% if layout_validation.invalid %][[ 1 / 0 ]][% endif %]
