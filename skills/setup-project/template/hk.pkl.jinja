amends "package://github.com/jdx/hk/releases/download/v1.49.0/hk@1.49.0#/Config.pkl"
import "package://github.com/jdx/hk/releases/download/v1.49.0/hk@1.49.0#/Builtins.pkl"

local commit_message_beads = new Step {
  check =
    #"""
    awk '
      /^# ------------------------ >8 ------------------------/ { exit }
      /^diff --git / { exit }
      /^#/ { next }
      /^(Refs?|Tasks?|Issues?):/ {
        printf "use the canonical Beads: footer instead of: %s\n", $0 > "/dev/stderr"
        failed = 1
      }
      /^Beads:/ {
        beads += 1
        if ($0 !~ /^Beads: [a-z][a-z0-9-]*-[a-z0-9][a-z0-9.-]*(, [a-z][a-z0-9-]*-[a-z0-9][a-z0-9.-]*)*$/) {
          printf "invalid Beads footer: %s\n", $0 > "/dev/stderr"
          failed = 1
        }
      }
      NF { last = $0 }
      END {
        if (beads > 1) {
          print "commit message must contain at most one Beads: footer" > "/dev/stderr"
          failed = 1
        }
        if (beads == 1 && last !~ /^Beads:/) {
          print "Beads: must be the final nonblank line" > "/dev/stderr"
          failed = 1
        }
        exit failed
      }
    ' {{commit_msg_file}}
    """#
}

local commit_message_length = new Step {
  check =
    #"""
    awk '
      /^# ------------------------ >8 ------------------------/ { exit }
      /^diff --git / { exit }
      /^#/ { next }
      {
        line += 1
        limit = line == 1 ? 72 : 100
        if (length($0) > limit) {
          printf "commit message line %d is %d characters; maximum is %d\n", line, length($0), limit > "/dev/stderr"
          failed = 1
        }
      }
      END { exit failed }
    ' {{commit_msg_file}}
    """#
}

local commit_message_scope = new Step {
  check =
    #"""
    awk '
      /^# ------------------------ >8 ------------------------/ { exit }
      /^diff --git / { exit }
      /^#/ { next }
      NF {
        if ($0 ~ /^(feat|fix|perf|refactor)!?: /) {
          print "changelog-visible commit subject must use type(scope): summary" > "/dev/stderr"
          exit 1
        }
        exit 0
      }
    ' {{commit_msg_file}}
    """#
}

local harper_commit_message = (Builtins.harper_commit_message) {
  check =
    #"""
    awk '
      /^# ------------------------ >8 ------------------------/ { exit }
      /^diff --git / { exit }
      /^#/ { next }
      NR == 1 && /^release: v[0-9]+\.[0-9]+\.[0-9]+$/ { next }
      /^Beads: [a-z][a-z0-9-]*-[a-z0-9][a-z0-9.-]*(, [a-z][a-z0-9-]*-[a-z0-9][a-z0-9.-]*)*$/ { next }
      { print }
    ' {{commit_msg_file}} | harper-cli lint --quiet --no-color
    """#
}

local linters = new Mapping<String, Step> {
  ["byte_order_marker"] = Builtins.byte_order_marker
  ["check_case_conflict"] = Builtins.check_case_conflict
  ["check_executables_have_shebangs"] = Builtins.check_executables_have_shebangs
  ["check_merge_conflict"] = Builtins.check_merge_conflict
  ["contextlint"] = new Step {
    glob = List("README.md", "docs/**/*.md", "contextlint.config.json")
    check = "contextlint"
  }
  ["detect_private_key"] = Builtins.detect_private_key
  ["docs"] = new Step {
    depends = "mise"
    glob = List("docs/src/**/*.md", "docs/book.toml", "scripts/check-docs.py")
    check = "uv run scripts/check-docs.py && mdbook build docs"
  }
  ["fix_smart_quotes"] = (Builtins.fix_smart_quotes) {
    depends = "byte_order_marker"
  }
  ["markdown-table-formatter"] = new Step {
    depends = "fix_smart_quotes"
    glob = List("**/*.md", "**/*.markdown")
    check_diff = "markdown-table-formatter --check {{ files }}"
    fix = "markdown-table-formatter {{ files }}"
  }
  ["mise"] = (Builtins.mise) {
    depends = "trailing_whitespace"
  }
  ["newlines"] = (Builtins.newlines) {
    depends = "markdown-table-formatter"
  }
  ["rumdl"] = new Step {
    depends = "newlines"
    glob = List("**/*.md", "**/*.markdown")
    check = "rumdl check --config .config/rumdl.toml {{ files }}"
    fix = "rumdl check --config .config/rumdl.toml --fix {{ files }}"
  }
  ["trailing_whitespace"] = (Builtins.trailing_whitespace) {
    depends = "rumdl"
  }
[% if 'python' in language_profiles %]
  ["ruff"] = new Step {
    depends = "mise"
    glob = List("**/*.py", "**/*.pyi")
    check = "ruff check --force-exclude {{ files }}"
    fix = "ruff check --force-exclude --fix {{ files }}"
  }
  ["ruff-format"] = new Step {
    depends = "ruff"
    glob = List("**/*.py", "**/*.pyi")
    check_diff = "ruff format --quiet --force-exclude --diff {{ files }}"
    fix = "ruff format --quiet --force-exclude {{ files }}"
  }
  ["ty"] = new Step {
    depends = "ruff-format"
    glob = List("**/*.py", "**/*.pyi")
    check = "ty check {{ files }}"
  }
[% endif %]
[% if 'typescript' in language_profiles %]
  ["biome"] = new Step {
    depends = "[% if 'python' in language_profiles %]ty[% else %]mise[% endif %]"
    glob = List("**/*.ts", "**/*.tsx", "**/*.mts", "**/*.cts")
    check = "biome check --no-errors-on-unmatched {{ files }}"
    fix = "biome check --write --no-errors-on-unmatched {{ files }}"
  }
[% endif %]
[% if 'rust' in language_profiles %]
  ["rustfmt"] = new Step {
    depends = "[% if 'typescript' in language_profiles %]biome[% elif 'python' in language_profiles %]ty[% else %]mise[% endif %]"
    glob = List("**/*.rs")
    check = "rustfmt --check --edition 2024 {{ files }}"
    fix = "rustfmt --edition 2024 {{ files }}"
  }
[% endif %]
[% if 'go' in language_profiles %]
  ["goimports"] = new Step {
    depends = "[% if 'rust' in language_profiles %]rustfmt[% elif 'typescript' in language_profiles %]biome[% elif 'python' in language_profiles %]ty[% else %]mise[% endif %]"
    glob = List("**/*.go")
    check = "output=$(goimports -l {{ files }}) && test -z \"$output\""
    fix = "goimports -w {{ files }}"
  }
  ["gofumpt"] = new Step {
    depends = "goimports"
    glob = List("**/*.go")
    check = "output=$(gofumpt -l {{ files }}) && test -z \"$output\""
    fix = "gofumpt -w {{ files }}"
  }
[% endif %]
[% if 'elixir' in language_profiles %]
  ["mix-format"] = new Step {
    depends = "[% if 'go' in language_profiles %]gofumpt[% elif 'rust' in language_profiles %]rustfmt[% elif 'typescript' in language_profiles %]biome[% elif 'python' in language_profiles %]ty[% else %]mise[% endif %]"
    glob = List("**/*.ex", "**/*.exs")
    check = "mix format --check-formatted {{ files }}"
    fix = "mix format {{ files }}"
  }
[% endif %]
[% if 'nix' in language_profiles %]
  ["nixfmt"] = new Step {
    depends = "[% if 'elixir' in language_profiles %]mix-format[% elif 'go' in language_profiles %]gofumpt[% elif 'rust' in language_profiles %]rustfmt[% elif 'typescript' in language_profiles %]biome[% elif 'python' in language_profiles %]ty[% else %]mise[% endif %]"
    glob = List("**/*.nix")
    check = "[ \"$(uname -s)/$(uname -m)\" != Darwin/x86_64 ] || { printf '%s\\n' 'Nix profile does not support macOS x64' >&2; exit 1; }; nixfmt --check {{ files }}"
    fix = "[ \"$(uname -s)/$(uname -m)\" != Darwin/x86_64 ] || { printf '%s\\n' 'Nix profile does not support macOS x64' >&2; exit 1; }; nixfmt {{ files }}"
  }
[% endif %]
  ["typos"] = (Builtins.typos) {
    depends = "[% if 'nix' in language_profiles %]nixfmt[% elif 'elixir' in language_profiles %]mix-format[% elif 'go' in language_profiles %]gofumpt[% elif 'rust' in language_profiles %]rustfmt[% elif 'typescript' in language_profiles %]biome[% elif 'python' in language_profiles %]ty[% else %]mise[% endif %]"
  }
}

hooks {
  ["commit-msg"] {
    steps {
      ["cocogitto_commit_msg"] = Builtins.cocogitto_commit_msg
      ["harper_commit_message"] = harper_commit_message
      ["commit_message_beads"] = commit_message_beads
      ["commit_message_length"] = commit_message_length
      ["commit_message_scope"] = commit_message_scope
    }
  }
  ["pre-commit"] {
    fix = true
    stash = "git"
    steps = linters
  }
  ["check"] {
    steps = (linters) {
[% if 'python' in language_profiles %]
      ["pytest"] = new Step {
        glob = List("tests/**/*.py")
        check = "[ ! -f pyproject.toml ] || { uv run python -c 'import pytest' || { printf '%s\\n' 'Python profile requires project-owned pytest' >&2; exit 1; }; uv run pytest; }"
      }
[% endif %]
[% if 'typescript' in language_profiles %]
      ["vitest"] = new Step {
        glob = List("**/*.test.ts", "**/*.test.tsx", "**/*.test.mts", "**/*.test.cts", "**/*.spec.ts", "**/*.spec.tsx", "**/*.spec.mts", "**/*.spec.cts")
        check = "[ ! -f package.json ] || { aube exec vitest --version >/dev/null || { printf '%s\\n' 'TypeScript profile requires project-owned Vitest' >&2; exit 1; }; aube exec vitest run; }"
      }
[% endif %]
[% if 'rust' in language_profiles %]
      ["cargo-clippy"] = new Step {
        check = "[ ! -f Cargo.toml ] || cargo clippy --all-targets --all-features -- -D warnings"
      }
      ["cargo-test"] = new Step {
        check = "[ ! -f Cargo.toml ] || cargo test --all-targets --all-features"
      }
[% endif %]
[% if 'go' in language_profiles %]
      ["go-mod"] = new Step {
        depends = "gofumpt"
        check = "[ ! -f go.mod ] || { go mod tidy -diff && go mod verify; }"
      }
      ["golangci-lint"] = new Step {
        depends = "go-mod"
        check = "[ ! -f go.mod ] || golangci-lint run"
      }
      ["go-test"] = new Step {
        depends = "go-mod"
        check = "[ ! -f go.mod ] || go test ./..."
      }
[% endif %]
[% if 'elixir' in language_profiles %]
      ["mix-compile"] = new Step {
        check = "[ ! -f mix.exs ] || mix compile --warnings-as-errors"
      }
      ["credo"] = new Step {
        check = "[ ! -f mix.exs ] || { mix help credo >/dev/null || { printf '%s\\n' 'Elixir profile requires project-owned Credo' >&2; exit 1; }; mix credo --strict; }"
      }
      ["mix-test"] = new Step {
        glob = List("test/**/*.exs")
        check = "[ ! -f mix.exs ] || mix test --warnings-as-errors"
      }
[% endif %]
[% if 'nix' in language_profiles %]
      ["nix-flake-check"] = new Step {
        check = "[ ! -f flake.nix ] || { [ \"$(uname -s)/$(uname -m)\" != Darwin/x86_64 ] || { printf '%s\\n' 'Nix profile does not support macOS x64' >&2; exit 1; }; command -v nix >/dev/null || { printf '%s\\n' 'Nix profile requires system nix for flake checks' >&2; exit 1; }; nix flake check; }"
      }
[% endif %]
    }
  }
  ["fix"] {
    fix = true
    steps = (linters) {
[% if 'go' in language_profiles %]
      ["go-mod"] = new Step {
        depends = "gofumpt"
        check = "[ ! -f go.mod ] || go mod tidy -diff"
        fix = "[ ! -f go.mod ] || go mod tidy"
      }
[% endif %]
    }
  }
}
