amends "package://github.com/jdx/hk/releases/download/v1.49.0/hk@1.49.0#/Config.pkl"
import "package://github.com/jdx/hk/releases/download/v1.49.0/hk@1.49.0#/Builtins.pkl"

local linters = new Mapping<String, Step> {
  ["byte_order_marker"] = Builtins.byte_order_marker
  ["check_case_conflict"] = Builtins.check_case_conflict
  ["check_executables_have_shebangs"] = Builtins.check_executables_have_shebangs
  ["check_merge_conflict"] = Builtins.check_merge_conflict
  ["detect_private_key"] = Builtins.detect_private_key
  ["docs"] = new Step {
    depends = "mise"
    glob = List("docs/src/**/*.md", "docs/book.toml", "scripts/check-docs.py")
    check = "uv run scripts/check-docs.py && mdbook build docs"
  }
  ["fix_smart_quotes"] = (Builtins.fix_smart_quotes) {
    depends = "byte_order_marker"
  }
  ["markdown-table-formatter"] = new Step {
    depends = "fix_smart_quotes"
    glob = List("**/*.md", "**/*.markdown")
    check_diff = "markdown-table-formatter --check {{ files }}"
    fix = "markdown-table-formatter {{ files }}"
  }
  ["mise"] = (Builtins.mise) {
    depends = "trailing_whitespace"
  }
  ["newlines"] = (Builtins.newlines) {
    depends = "markdown-table-formatter"
  }
  ["rumdl"] = new Step {
    depends = "newlines"
    glob = List("**/*.md", "**/*.markdown")
    check = "rumdl check --config .config/rumdl.toml {{ files }}"
    fix = "rumdl check --config .config/rumdl.toml --fix {{ files }}"
  }
  ["trailing_whitespace"] = (Builtins.trailing_whitespace) {
    depends = "rumdl"
  }
[% if 'python' in language_profiles %]
  ["ruff"] = new Step {
    depends = "mise"
    glob = List("**/*.py", "**/*.pyi")
    check = "ruff check --force-exclude {{ files }}"
    fix = "ruff check --force-exclude --fix {{ files }}"
  }
  ["ruff-format"] = new Step {
    depends = "ruff"
    glob = List("**/*.py", "**/*.pyi")
    check_diff = "ruff format --quiet --force-exclude --diff {{ files }}"
    fix = "ruff format --quiet --force-exclude {{ files }}"
  }
  ["ty"] = new Step {
    depends = "ruff-format"
    glob = List("**/*.py", "**/*.pyi")
    check = "ty check {{ files }}"
  }
[% endif %]
[% if 'typescript' in language_profiles %]
  ["biome"] = new Step {
    depends = "[% if 'python' in language_profiles %]ty[% else %]mise[% endif %]"
    glob = List("**/*.ts", "**/*.tsx", "**/*.mts", "**/*.cts")
    check = "biome check --no-errors-on-unmatched {{ files }}"
    fix = "biome check --write --no-errors-on-unmatched {{ files }}"
  }
[% endif %]
[% if 'rust' in language_profiles %]
  ["rustfmt"] = new Step {
    depends = "[% if 'typescript' in language_profiles %]biome[% elif 'python' in language_profiles %]ty[% else %]mise[% endif %]"
    glob = List("**/*.rs")
    check = "rustfmt --check --edition 2024 {{ files }}"
    fix = "rustfmt --edition 2024 {{ files }}"
  }
[% endif %]
[% if 'go' in language_profiles %]
  ["goimports"] = new Step {
    depends = "[% if 'rust' in language_profiles %]rustfmt[% elif 'typescript' in language_profiles %]biome[% elif 'python' in language_profiles %]ty[% else %]mise[% endif %]"
    glob = List("**/*.go")
    check = "test -z \"$(goimports -l {{ files }})\""
    fix = "goimports -w {{ files }}"
  }
  ["gofumpt"] = new Step {
    depends = "goimports"
    glob = List("**/*.go")
    check = "test -z \"$(gofumpt -l {{ files }})\""
    fix = "gofumpt -w {{ files }}"
  }
[% endif %]
  ["typos"] = (Builtins.typos) {
    depends = "[% if 'go' in language_profiles %]gofumpt[% elif 'rust' in language_profiles %]rustfmt[% elif 'typescript' in language_profiles %]biome[% elif 'python' in language_profiles %]ty[% else %]mise[% endif %]"
  }
}

hooks {
  ["pre-commit"] {
    fix = true
    stash = "git"
    steps = linters
  }
  ["check"] {
    steps = (linters) {
[% if 'python' in language_profiles %]
      ["pytest"] = new Step {
        glob = List("tests/**/*.py")
        check = "[ ! -f pyproject.toml ] || { uv run python -c 'import pytest' || { printf '%s\\n' 'Python profile requires project-owned pytest' >&2; exit 1; }; uv run pytest; }"
      }
[% endif %]
[% if 'typescript' in language_profiles %]
      ["vitest"] = new Step {
        glob = List("**/*.test.ts", "**/*.test.tsx", "**/*.test.mts", "**/*.test.cts", "**/*.spec.ts", "**/*.spec.tsx", "**/*.spec.mts", "**/*.spec.cts")
        check = "[ ! -f package.json ] || { aube exec vitest --version >/dev/null || { printf '%s\\n' 'TypeScript profile requires project-owned Vitest' >&2; exit 1; }; aube exec vitest run; }"
      }
[% endif %]
[% if 'rust' in language_profiles %]
      ["cargo-clippy"] = new Step {
        check = "[ ! -f Cargo.toml ] || cargo clippy --all-targets --all-features -- -D warnings"
      }
      ["cargo-test"] = new Step {
        check = "[ ! -f Cargo.toml ] || cargo test --all-targets --all-features"
      }
[% endif %]
[% if 'go' in language_profiles %]
      ["go-mod"] = new Step {
        depends = "gofumpt"
        check = "[ ! -f go.mod ] || { go mod tidy -diff && go mod verify; }"
      }
      ["golangci-lint"] = new Step {
        depends = "go-mod"
        check = "[ ! -f go.mod ] || golangci-lint run"
      }
      ["go-test"] = new Step {
        depends = "go-mod"
        check = "[ ! -f go.mod ] || go test ./..."
      }
[% endif %]
    }
  }
  ["fix"] {
    fix = true
    steps = (linters) {
[% if 'go' in language_profiles %]
      ["go-mod"] = new Step {
        depends = "gofumpt"
        check = "[ ! -f go.mod ] || go mod tidy -diff"
        fix = "[ ! -f go.mod ] || go mod tidy"
      }
[% endif %]
    }
  }
}
