#:schema https://mise.jdx.dev/schema/mise.json

[tools]
hk = "1.49.0"
cocogitto = "latest"
harper-cli = "latest"
"npm:@contextlint/cli" = { version = "latest", aube_args = "--allow-low-downloads" }
node = "lts"
mdbook = "latest"
uv = "latest"
rumdl = "latest"
typos = "latest"
"npm:markdown-table-formatter" = "latest"[% if 'python' in language_profiles %]
ruff = "latest"
ty = "latest"[% endif %][% if 'typescript' in language_profiles %]
aube = "latest"
biome = "latest"[% endif %][% if 'rust' in language_profiles %]
rust = { version = "latest", components = "rustfmt,clippy" }[% endif %][% if 'go' in language_profiles %]
go = "latest"
gofumpt = "latest"
"go:golang.org/x/tools/cmd/goimports" = "latest"
golangci-lint = "latest"[% endif %][% if 'elixir' in language_profiles %]
erlang = "latest"
elixir = "latest"[% endif %][% if 'nix' in language_profiles %]
"github:Mic92/nixfmt-rs" = { version = "latest", os = ["linux", "macos/arm64"] }[% endif %]

[env]
GIT_CONFIG_PARAMETERS = "'merge.ff=only'"
HK_MISE = 1

[tasks.check]
description = "Run repository validation"
run = "hk check -a"

[tasks.fix]
description = "Apply deterministic repository fixes"
run = "hk fix -a"

[tasks."docs:check"]
description = "Validate and build the documentation"
depends = ["docs:build"]
run = "uv run scripts/check-docs.py"

[tasks."docs:build"]
description = "Build the documentation site"
run = "mdbook build docs"

[tasks."docs:deployment:enable"]
description = "Enable GitHub Pages deployment"
run = "python3 scripts/enable-docs-deployment.py"

[tasks."docs:serve"]
description = "Serve the documentation site locally"
usage = 'arg "[port]" help="Port to serve on" default="3000"'
run = '''
#!/usr/bin/env bash
set -euo pipefail
mdbook serve docs --port "${usage_port:-3000}"
'''
